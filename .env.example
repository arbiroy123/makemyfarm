# ─── FarmSync Backend Environment Variables ───────────────────────────────────
# Copy to backend/.env and fill in your values.
# On Railway: set all variables in the Railway dashboard → Variables tab.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Railway: auto-provided when you add the PostgreSQL plugin.
# Local dev: use the docker-compose default below.
DATABASE_URL=postgresql://postgres:farmsync_dev@localhost:5432/farmsync

# Fallback individual vars (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=farmsync_dev
DB_NAME=farmsync
DB_PORT=5432

# ── Auth ──────────────────────────────────────────────────────────────────────
# IMPORTANT: use a strong random secret in production (openssl rand -hex 32)
JWT_SECRET=change_me_in_production

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Railway: add your Expo/Vercel URL here after deploy.
CORS_ORIGIN=http://localhost:3000,http://localhost:8081,http://localhost:19006

# ── Redis (optional — for future caching/pub-sub) ─────────────────────────────
# Railway: auto-provided when you add the Redis plugin.
REDIS_URL=redis://localhost:6379

# ── AI / Anthropic ────────────────────────────────────────────────────────────
# Required for KisanBot (AI Agronomist Chatbot).
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe Billing ────────────────────────────────────────────────────────────
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret — get from: stripe listen --forward-to localhost:3000/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for Pro plan — create at: https://dashboard.stripe.com/products
STRIPE_PRO_PRICE_ID=price_...
# Your app's URL (used for Stripe redirect URLs)
APP_URL=https://your-railway-app.up.railway.app
