# .env.example for Mobile App

# Backend API
EXPO_PUBLIC_API_URL=http://localhost:3000/api
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000

# Google Maps (optional, for web version)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key

# Mapbox (optional alternative to Google Maps)
EXPO_PUBLIC_MAPBOX_API_KEY=your_mapbox_api_key

# Feature Flags
EXPO_PUBLIC_ENABLE_COMMUNITY=true
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true
EXPO_PUBLIC_ENABLE_REAL_TIME=true
