{
  "expo": {
    "name": "FarmSync",
    "slug": "farmsync",
    "version": "1.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.farmsync.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4CAF50"
      },
      "package": "com.farmsync.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow FarmSync to access your location"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FarmSync to access your photos",
          "cameraPermission": "Allow FarmSync to access your camera"
        }
      ]
    ],
    "newArchEnabled": false,
    "extra": {
      "eas": {
        "projectId": "83a19ea8-0cdf-42db-a857-9a947e60b71a"
      }
    }
  }
}
