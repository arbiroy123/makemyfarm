import React, { useState, useEffect } from 'react';
import { View, Text, StyleSheet, ScrollView, ActivityIndicator, Platform } from 'react-native';
import { mapAPI } from '../../api/client';
import * as Location from 'expo-location';

// Conditionally import map components for web compatibility
let MapView, Marker;
if (Platform.OS !== 'web') {
  const Maps = require('react-native-maps');
  MapView = Maps.default;
  Marker = Maps.Marker;
}

export default function MapScreen() {
  const [userLocation, setUserLocation] = useState(null);
  const [nearbyFarms, setNearbyFarms] = useState([]);
  const [nearbyGroups, setNearbyGroups] = useState([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    initializeMap();
  }, []);

  const initializeMap = async () => {
    try {
      let { status } = await Location.requestForegroundPermissionsAsync();
      if (status !== 'granted') {
        console.error('Permission denied');
        return;
      }

      const location = await Location.getCurrentPositionAsync({});
      setUserLocation(location.coords);

      // Fetch nearby farms and groups
      const [farmsRes, groupsRes] = await Promise.all([
        mapAPI.getNearbyFarms(location.coords.latitude, location.coords.longitude, 15),
        mapAPI.getNearbyGroups(location.coords.latitude, location.coords.longitude, 15)
      ]);

      setNearbyFarms(farmsRes.data);
      setNearbyGroups(groupsRes.data);
    } catch (error) {
      console.error('Failed to initialize map:', error);
    } finally {
      setLoading(false);
    }
  };

  if (loading) {
    return (
      <View style={styles.centerContainer}>
        <ActivityIndicator size="large" color="#4CAF50" />
      </View>
    );
  }

  return (
    <View style={styles.container}>
      {userLocation ? (
        <MapView
          style={styles.map}
          initialRegion={{
            latitude: userLocation.latitude,
            longitude: userLocation.longitude,
            latitudeDelta: 0.0922,
            longitudeDelta: 0.0421
          }}
        >
          {/* User location */}
          <Marker
            coordinate={{
              latitude: userLocation.latitude,
              longitude: userLocation.longitude
            }}
            title="Your Location"
            pinColor="#4CAF50"
          />

          {/* Nearby farms */}
          {nearbyFarms.map((farm) => (
            <Marker
              key={farm.id}
              coordinate={{
                latitude: JSON.parse(farm.location.coordinates[1]),
                longitude: JSON.parse(farm.location.coordinates[0])
              }}
              title={farm.name}
              pinColor="#FF6B6B"
            />
          ))}

          {/* Nearby groups */}
          {nearbyGroups.map((group) => (
            <Marker
              key={group.id}
              coordinate={{
                latitude: JSON.parse(group.location.coordinates[1]),
                longitude: JSON.parse(group.location.coordinates[0])
              }}
              title={group.name}
              pinColor="#2196F3"
            />
          ))}
        </MapView>
      ) : (
        <View style={styles.centerContainer}>
          <Text>Unable to get location</Text>
        </View>
      )}

      <View style={styles.legend}>
        <View style={styles.legendItem}>
          <View style={[styles.legendDot, { backgroundColor: '#4CAF50' }]} />
          <Text style={styles.legendText}>Your Location</Text>
        </View>
        <View style={styles.legendItem}>
          <View style={[styles.legendDot, { backgroundColor: '#FF6B6B' }]} />
          <Text style={styles.legendText}>Community Farms</Text>
        </View>
        <View style={styles.legendItem}>
          <View style={[styles.legendDot, { backgroundColor: '#2196F3' }]} />
          <Text style={styles.legendText}>Community Groups</Text>
        </View>
      </View>
    </View>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1
  },
  map: {
    flex: 1
  },
  centerContainer: {
    flex: 1,
    justifyContent: 'center',
    alignItems: 'center'
  },
  legend: {
    position: 'absolute',
    bottom: 20,
    left: 15,
    right: 15,
    backgroundColor: '#fff',
    borderRadius: 8,
    padding: 12,
    shadowColor: '#000',
    shadowOffset: { width: 0, height: 2 },
    shadowOpacity: 0.2,
    shadowRadius: 3,
    elevation: 5
  },
  legendItem: {
    flexDirection: 'row',
    alignItems: 'center',
    marginBottom: 8
  },
  legendDot: {
    width: 12,
    height: 12,
    borderRadius: 6,
    marginRight: 8
  },
  legendText: {
    fontSize: 12,
    color: '#333'
  }
});
